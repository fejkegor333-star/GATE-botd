# Gate.io API
GATE_API_KEY=your_api_key_here
GATE_API_SECRET=your_api_secret_here
# API URLs
GATE_API_URL=https://api.gateio.ws
GATE_WS_URL=wss://fx-ws.gateio.ws/v4/ws/usdt
GATE_TESTNET=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gate_bot
DB_USER=gate_bot
DB_PASSWORD=your_password_here

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=0

# Sentry
SENTRY_DSN=

# Modes
DEBUG=false
DRY_RUN=false
LOG_LEVEL=INFO

# Timeouts
API_TIMEOUT=30
WS_TIMEOUT=10
